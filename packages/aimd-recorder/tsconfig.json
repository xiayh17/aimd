{
  "extends": "../../tsconfig.node.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "types": ["node"],
    "paths": {
      "@airalogy/aimd-editor/vue": ["../aimd-editor/src/vue/index.ts"],
      "@airalogy/aimd-editor/embedded": ["../aimd-editor/src/embedded.ts"],
      "@airalogy/aimd-editor/wysiwyg": ["../aimd-editor/src/wysiwyg.ts"],
      "@airalogy/aimd-editor/monaco": ["../aimd-editor/src/monaco.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
